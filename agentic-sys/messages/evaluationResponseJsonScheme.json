{
  "name": "todo_free_answer_evaluation",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "question",
      "studentAnswer",
      "status",
      "studentFeedback",
      "teacherFeedback"
    ],
    "properties": {
      "question": {
        "type": "string"
      },
      "studentAnswer": {
        "type": "string"
      },
      "status": {
        "type": "string",
        "enum": [
          "correct",
          "needs-improvement",
          "incorrect",
          "flag-for-teacher"
        ]
      },
      "studentFeedback": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "teacherFeedback": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}